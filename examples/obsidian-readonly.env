# Obsidian vault — read-only with Ollama embeddings
# MARKDOWN_VAULT_MCP_SERVER_NAME=obsidian-vault
MARKDOWN_VAULT_MCP_INSTRUCTIONS=Personal Obsidian knowledge base (read-only). Contains notes, journal entries, and project references. Semantic search available — use mode='hybrid' for best results. Write tools are NOT available on this instance.
MARKDOWN_VAULT_MCP_SOURCE_DIR=/home/user/Obsidian
MARKDOWN_VAULT_MCP_READ_ONLY=true
MARKDOWN_VAULT_MCP_EXCLUDE=.obsidian/**,.trash/**,_templates/**

# Periodic git sync (ff-only). Default is 600s; set to 0 to disable.
# MARKDOWN_VAULT_MCP_GIT_PULL_INTERVAL_S=600

# Attachments: default list allows common document and image formats.
# Uncomment to restrict to specific extensions, or use * for all non-.md files.
# MARKDOWN_VAULT_MCP_ATTACHMENT_EXTENSIONS=pdf,png,jpg,jpeg
# MARKDOWN_VAULT_MCP_MAX_ATTACHMENT_SIZE_MB=10

EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
MARKDOWN_VAULT_MCP_OLLAMA_MODEL=nomic-embed-text
