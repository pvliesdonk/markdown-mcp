# Obsidian vault — read-only with Ollama embeddings
# MARKDOWN_VAULT_MCP_SERVER_NAME=obsidian-vault
# MARKDOWN_VAULT_MCP_INSTRUCTIONS=Personal Obsidian knowledge base. Read-only. Use 'search' to find notes.
MARKDOWN_VAULT_MCP_SOURCE_DIR=/home/user/Obsidian
MARKDOWN_VAULT_MCP_READ_ONLY=true
MARKDOWN_VAULT_MCP_EXCLUDE=.obsidian/**,.trash/**,_templates/**
EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
MARKDOWN_VAULT_MCP_OLLAMA_MODEL=nomic-embed-text
