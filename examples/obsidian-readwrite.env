# Obsidian vault — read-write with git auto-commit
# MARKDOWN_VAULT_MCP_SERVER_NAME=obsidian-vault
MARKDOWN_VAULT_MCP_INSTRUCTIONS=Personal Obsidian vault (read-write). Contains notes, journal entries, and project references. Semantic search available — use mode='hybrid' for best results. Use 'write' to create notes, 'edit' for targeted changes (read first), 'rename' to reorganize. All writes are auto-committed and pushed to git.
MARKDOWN_VAULT_MCP_SOURCE_DIR=/data/vault
MARKDOWN_VAULT_MCP_READ_ONLY=false
MARKDOWN_VAULT_MCP_EXCLUDE=.obsidian/**,.trash/**,_templates/**

# Git auto-commit. Replace with your GitHub/GitLab PAT.
MARKDOWN_VAULT_MCP_GIT_TOKEN=ghp_your_token_here
# MARKDOWN_VAULT_MCP_GIT_PUSH_DELAY_S=30
# Required in Docker where git config user.name is unset:
# MARKDOWN_VAULT_MCP_GIT_COMMIT_NAME=markdown-vault-mcp
# MARKDOWN_VAULT_MCP_GIT_COMMIT_EMAIL=noreply@markdown-vault-mcp

# Attachments: default list allows common document and image formats.
# Uncomment to restrict to specific extensions, or use * for all non-.md files.
# MARKDOWN_VAULT_MCP_ATTACHMENT_EXTENSIONS=pdf,png,jpg,jpeg
# MARKDOWN_VAULT_MCP_MAX_ATTACHMENT_SIZE_MB=10

EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
MARKDOWN_VAULT_MCP_OLLAMA_MODEL=nomic-embed-text
